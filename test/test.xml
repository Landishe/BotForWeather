    <test-case id="weatherNow - night">
        <dateTime>2026-02-25 00:30:00</dateTime>
        <mockData>
            <query method="get">https://api.open-meteo.com/v1/forecast?latitude=${latitude}&amp;longitude=${longitude}&amp;timezone=${timezone}&amp;current=${current}&amp;daily=${daily}</query>
